# Firebase（クライアント）
# Firebase Console → プロジェクトの設定 → 全般 → マイアプリ（Web アプリ）の firebaseConfig から転記
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK（サーバー・API Routes 用）
# Firebase Console → プロジェクトの設定 → サービスアカウント → 新しい秘密鍵の生成（JSON）から転記
# ※ private_key は複数行のため、必ずダブルクォートで囲む（\n はそのまま）
#   例: FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Claude API（https://platform.claude.com → API Keys。spend limit の設定も忘れずに）
ANTHROPIC_API_KEY=

# OpenAI API（Embeddings 用。https://platform.openai.com → API Keys）
OPENAI_API_KEY=
